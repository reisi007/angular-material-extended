{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../dist/out-tsc",
    "declaration": true,
    "declarationMap": true,
    "inlineSources": true,
    "types": []
  },
  "include": [
    "src/**/*.ts",
    "cropper/src/**/*.ts",
    "data-table/src/**/*.ts",
    "file-upload/src/**/*.ts",
    "toast/src/**/*.ts"
  ],
  "exclude": [
    "src/**/*.spec.ts",
    "src/**/*.test.ts",
    "cropper/src/**/*.spec.ts",
    "cropper/src/**/*.test.ts",
    "data-table/src/**/*.spec.ts",
    "data-table/src/**/*.test.ts",
    "file-upload/src/**/*.spec.ts",
    "file-upload/src/**/*.test.ts",
    "toast/src/**/*.spec.ts",
    "toast/src/**/*.test.ts"
  ]
}
