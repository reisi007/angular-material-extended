{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../dist/out-tsc",
    "declaration": true,
    "declarationMap": true,
    "inlineSources": true,
    "skipLibCheck": true,
    "types": []
  },
  "include": [
    "src/**/*.ts",
    "cropper/src/**/*.ts",
    "data-table/src/**/*.ts",
    "file-upload/src/**/*.ts",
    "toast/src/**/*.ts",
    "menu/src/**/*.ts",
    "dialog/src/**/*.ts",
    "i18n/src/**/*.ts"
  ],
  "exclude": [
    "src/**/*.spec.ts",
    "src/**/*.test.ts",
    "cropper/src/**/*.spec.ts",
    "cropper/src/**/*.test.ts",
    "data-table/src/**/*.spec.ts",
    "data-table/src/**/*.test.ts",
    "file-upload/src/**/*.spec.ts",
    "file-upload/src/**/*.test.ts",
    "toast/src/**/*.spec.ts",
    "toast/src/**/*.test.ts",
    "menu/src/**/*.spec.ts",
    "menu/src/**/*.test.ts",
    "dialog/src/**/*.spec.ts",
    "dialog/src/**/*.test.ts",
    "i18n/src/**/*.spec.ts",
    "i18n/src/**/*.test.ts"
  ],
  "angularCompilerOptions": {
    "fullTemplateTypeCheck": true,
    "strictInjectionParameters": true
  }
}
